# TradeSnow2 — copy to .env and fill with your own values (never commit .env)
NODE_ENV=production

# Auth
JWT_SECRET=replace-with-at-least-32-char-random-secret
OWNER_OPEN_ID=your-owner-open-id

# Database (TiDB / MySQL)
DATABASE_URL=mysql://user:password@host:4000/dbname?ssl={"rejectUnauthorized":true}

# IBKR live account (U-prefix, e.g. U12345678)
IBKR_LIVE_ACCOUNT_ID=

# IBIND OAuth bridge
IBIND_BASE_URL=http://127.0.0.1:5000
IBIND_API_SECRET=your-ibind-api-secret
IBIND_HMAC_SECRET=your-ibind-hmac-secret-min-32-chars

# Optional integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
LOG_SECRET=
GEMINI_API_KEY=
SUPADATA_API_KEY=
OPENAI_API_KEY=

# Paper trading (optional)
PAPER_API_BASE_URL=https://tradesnow.vip/paper-api
PAPER_API_BEARER_TOKEN=
PAPER_IBIND_API_SECRET=

# Daily loss circuit breaker (Iron Rule 4)
DAILY_LOSS_LIMIT_USD=2000

# Google Drive handoff (optional — see docs/superpowers/gdrive-auth-setup.md)
GDRIVE_REMOTE_NAME=tradesnow-gdrive
GDRIVE_HANDOFF_FOLDER=TradeSnow/Manual Trading UX
GDRIVE_SERVICE_ACCOUNT_FILE=secrets/google-service-account.json
