// ── RiskReturnGauge ──────────────────────────────────────────────────────────
function RiskReturnGauge({ grand, monthlyStartNlv, rowCount }: {
  grand: number;
  monthlyStartNlv: number;
  rowCount: number;
}) {
  const pct    = monthlyStartNlv > 0 ? (grand / monthlyStartNlv) * 100 : 0;
  const absPct = Math.abs(pct);
  const isPos  = grand >= 0;
  // Bar fill: 0–10% range → 0–100% width
  const fill   = Math.min(100, (absPct / 10) * 100);
  const color  = isPos ? "#10b981" : "#ef4444";
  const label  = isPos ? `+${pct.toFixed(2)}%` : `${pct.toFixed(2)}%`;

  return (
    <div className="mx-4 mb-4 mt-3 rounded-xl border border-gray-200 bg-gray-50 px-4 py-3">
      <div className="flex items-center justify-between mb-2">
        <span className="text-[11px] font-bold uppercase tracking-widest text-gray-500">📊 Monthly P&L vs Risk</span>
        <span className="text-sm font-black font-mono" style={{ color }}>{label}</span>
      </div>
      <div className="relative h-3 bg-gray-200 rounded-full overflow-hidden">
        <div
          className="absolute top-0 h-full rounded-full transition-all duration-500"
          style={{ width: `${fill}%`, background: color, left: isPos ? "50%" : `${50 - fill/2}%`, transform: isPos ? "none" : "none" }}
        />
        {/* Center line */}
        <div className="absolute top-0 bottom-0 w-px bg-gray-400" style={{ left: "50%" }}/>
      </div>
      <div className="flex justify-between mt-1">
        <span className="text-[10px] text-slate-500">-10%</span>
        <span className="text-[10px] text-slate-500 font-semibold">{rowCount} פוזיציות</span>
        <span className="text-[10px] text-slate-500">+10%</span>
      </div>
    </div>
  );
}



// ── Isolated clock — renders independently, no page re-render every second ──
function HeaderClock() {
  const [now, setNow] = useState(new Date());
  useEffect(() => {
    const id = setInterval(() => setNow(new Date()), 1000);
    return () => clearInterval(id);
  }, []);
  const israel = now.toLocaleTimeString("he-IL", { timeZone: "Asia/Jerusalem", hour: "2-digit", minute: "2-digit", second: "2-digit" });
  const utc    = now.toLocaleTimeString("en-GB", { timeZone: "UTC",            hour: "2-digit", minute: "2-digit" });
  return <span className="text-xs font-mono text-slate-400">{israel} IL / {utc} UTC</span>;
}


