      </div>
    </div>
  );
}

function pnlTone(n: number) {
  return n >= 0 ? "text-green-600" : "text-red-600";
}

function winRateTone(rate: number) {
  if (rate >= 55) return "text-green-600";
  if (rate >= 45) return "text-amber-600";
  return "text-red-600";
}

