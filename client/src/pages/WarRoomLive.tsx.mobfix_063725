// ── FlickerCell: Bloomberg-style tick flash on value change ──────────────────
function FlickerCell({ value, fmt, className }: {
  value: number | null | undefined;
  fmt: (v: number) => string;
  className?: string;
}) {
  const prev = useRef<number | null | undefined>(value);
  const [flash, setFlash] = useState<"up"|"down"|null>(null);
  useEffect(() => {
    if (value == null || prev.current == null) { prev.current = value; return; }
    if (value > prev.current) setFlash("up");
    else if (value < prev.current) setFlash("down");
    prev.current = value;
    const id = setTimeout(() => setFlash(null), 600);
    return () => clearTimeout(id);
  }, [value]);
  return (
    <span className={cn(
      "font-mono font-bold tabular-nums transition-colors duration-150",
      flash === "up"   && "text-emerald-400",
      flash === "down" && "text-red-400",
      className
    )}>
      {value == null ? "—" : fmt(value)}
    </span>
  );
}

// ── SkeletonVal: prevents layout shift during loading ────────────────────────
function SkeletonVal({ isLoading, value, className }: {
  isLoading: boolean; value: React.ReactNode; className?: string;
}) {
  if (isLoading) return (
    <span className={cn("inline-block h-4 w-16 rounded bg-gray-200 animate-pulse align-middle", className)}/>
  );
  return <span className={className}>{value}</span>;
}

// ── SlTpBadge: checks IBKR live orders for SL/TP coverage ───────────────────
// IBKR returns orderType="Limit" (capital L), qty as totalSize/remainingQuantity
function SlTpBadge({ label, ibkrOrders, ticker, units, type, ibkrOrderId }:
  { label:"SL"|"TP"; ibkrOrders:any[]; ticker:string; units:number; type:"SL"|"TP"; ibkrOrderId?:string|null }) {
  const match = ibkrOrders.filter((o:any) => {
    const isTicker = (o.ticker ?? o.description1 ?? "").toUpperCase() === ticker.toUpperCase();
    const rawType  = (o.orderType ?? "").toUpperCase().trim();
    const isSell   = (o.side ?? "").toUpperCase().startsWith("S");
    const isSide   = type === "SL"
      ? (rawType === "STP" || rawType === "STOP" || rawType === "STOP_LIMIT" || rawType.startsWith("STOP") || rawType.startsWith("TRAIL"))
      : (rawType === "LMT" || rawType === "LIMIT");
    const isActive = o.status === "PreSubmitted" || o.status === "Submitted";
    return isTicker && isSide && isSell && isActive;
  });
  const found = match.length > 0;
  const qtyOk = found && match.some((o:any) => Math.abs((o.qty ?? 0) - units) < 0.5);
  const synced = found && qtyOk;

  // Fallback: if order not in live feed (old session) but DB has the orderId — show confirmed
  const dbConfirmed = !found && !!ibkrOrderId;

  if (synced) return (
    <div className="flex flex-col items-end gap-0.5">
      <span className="text-emerald-600 font-bold text-sm">✅</span>
      <span className="text-[9px] font-mono text-emerald-500">
        {(() => {
          const raw = match[0];
          // auxPrice = Stop trigger; price/lmtPrice = Limit; fallback to "MKT"
          const v = parseFloat(raw?.auxPrice) || parseFloat(raw?.price) || parseFloat(raw?.lmtPrice) || 0;
          return v > 0 ? fmt$(v, 2) : "MKT";
        })()}
      </span>
    </div>
  );
  if (dbConfirmed) return (
    <div className="flex flex-col items-end gap-0.5">
      <span className="text-emerald-600 font-bold text-sm">✅</span>
      <span className="text-[9px] font-mono text-emerald-400">#{ibkrOrderId}</span>
    </div>
  );
  return (
    <div className="flex flex-col items-end gap-0.5">
      <span className="text-red-500 font-bold text-sm">✗</span>
      {found && !qtyOk && <span className="text-[9px] font-mono text-amber-500">qty?</span>}
      {!found && <span className="text-[9px] font-mono text-slate-500">missing</span>}
    </div>
  );
}

// ── SyncStatusBox ──────────────────────────────────────────────────────────────
function SyncStatusBox({ lastFetch, isLoading }:{ lastFetch:Date|null; isLoading:boolean }) {
  const secAgo = lastFetch ? Math.floor((Date.now() - lastFetch.getTime()) / 1000) : null;
  const synced = secAgo != null && secAgo < 30;
  return (
    <div className="flex flex-col gap-1 w-full h-full">
      <div className="text-[10px] font-bold uppercase tracking-widest text-gray-800 mb-1">SYNC</div>
      <div className="flex items-center gap-2">
        {isLoading ? <Loader2 className="w-4 h-4 text-violet-500 animate-spin"/> :
          synced ? <Wifi className="w-4 h-4 text-emerald-600"/> : <WifiOff className="w-4 h-4 text-amber-500"/>}
        <span className={cn("text-[10px] font-bold uppercase tracking-wide",
          synced ? "text-emerald-700" : "text-amber-700")}>
          {isLoading ? "SYNCING…" : synced ? "SYNC ✓" : "STALE"}
        </span>
      </div>
      <div className="flex items-center gap-1 text-[9px] font-mono text-gray-500">
        <Clock className="w-3 h-3"/>
        <span>{lastFetch ? fmtTime(lastFetch) : "—"}</span>
